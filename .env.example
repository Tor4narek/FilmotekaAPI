# Copy this to .env and fill in your values

# PostgreSQL
POSTGRES_DB=filmoteka
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here

# Application settings (override appsettings.json)
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=filmoteka;Username=postgres;Password=your_strong_password_here
ConnectionStrings__Redis=redis:6379

Kinopoisk__ApiKey=your_kinopoisk_api_key_here

Jwt__Secret=your_very_long_random_jwt_secret_at_least_32_characters_long
Jwt__Issuer=filmoteka-api
Jwt__Audience=filmoteka-client
Jwt__AccessTokenExpiryMinutes=15
Jwt__RefreshTokenExpiryDays=7

# Set to /usr/bin/chromium in Docker; leave empty to auto-download for local dev
Puppeteer__ExecutablePath=/usr/bin/chromium
